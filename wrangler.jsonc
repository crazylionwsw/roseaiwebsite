{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "roseaiwebsite",
  "compatibility_date": "2026-06-25",
  "observability": {
    "enabled": true
  },
  "main": "workers/chat-api.js",
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "www.roseai.ca/api/chat",
      "zone_name": "roseai.ca"
    }
  ]
}
