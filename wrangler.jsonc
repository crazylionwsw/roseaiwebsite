{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "roseaiwebsite",
  "compatibility_date": "2026-06-25",
  "observability": {
    "enabled": true
  },
  "main": "workers/chat-api.js",
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
