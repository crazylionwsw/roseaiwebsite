# ============ DeepSeek ============
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ============ Vector Database (Upstash Vector) ============
# Get these from https://console.upstash.com/vector
VECTOR_DB_URL=https://xxx.upstash.io
VECTOR_DB_TOKEN=your-upstash-token
VECTOR_DB_BACKEND=upstash   # "upstash" or "local" (local = knowledge-base.json)

# ============ Google Drive Integration ============
# Base64-encoded Google Service Account JSON key
# See: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_SERVICE_ACCOUNT_JSON=base64-encoded-json-here
# The folder ID from the Google Drive folder URL
# e.g., https://drive.google.com/drive/folders/ABC123 → ABC123
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id
